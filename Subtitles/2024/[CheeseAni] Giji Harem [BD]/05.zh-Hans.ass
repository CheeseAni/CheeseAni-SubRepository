Dialogue: 0,0:00:04.49,0:00:07.03,jp,,0,0,0,,ほっぺ  触ってもいい？
Dialogue: 1,0:00:04.49,0:00:07.03,zh,,0,0,0,,我可以摸摸你的脸吗
Dialogue: 0,0:00:07.03,0:00:08.08,jp,,0,0,0,,いいよ
Dialogue: 1,0:00:07.03,0:00:08.08,zh,,0,0,0,,好啊
Dialogue: 0,0:00:09.35,0:00:12.00,jp,,0,0,0,,かわいいなぁ  マジで
Dialogue: 1,0:00:09.35,0:00:12.00,zh,,0,0,0,,真的好可爱啊
Dialogue: 0,0:00:30.59,0:00:34.09,jp,,0,0,0,,妹と遊んでもらって  ありがとうございます
Dialogue: 1,0:00:30.59,0:00:34.09,zh,,0,0,0,,谢谢你陪我妹妹玩
Dialogue: 0,0:00:34.09,0:00:38.53,jp,,0,0,0,,いやいや  でも綾香ちゃん  お姉ちゃんとそっくりだよなー
Dialogue: 1,0:00:34.09,0:00:38.53,zh,,0,0,0,,不谢不谢 不过绫香跟姐姐好像啊
Dialogue: 0,0:00:40.03,0:00:43.09,jp,,0,0,0,,綾香ちゃんは  お姉ちゃんのこと好き？
Dialogue: 1,0:00:40.03,0:00:43.09,zh,,0,0,0,,绫香喜欢姐姐吗
Dialogue: 0,0:00:43.09,0:00:44.08,jp,,0,0,0,,うん
Dialogue: 1,0:00:43.09,0:00:44.08,zh,,0,0,0,,嗯
Dialogue: 0,0:00:44.08,0:00:46.05,jp,,0,0,0,,どのお姉ちゃんが好き？
Dialogue: 1,0:00:44.08,0:00:46.05,zh,,0,0,0,,喜欢哪个姐姐呢
Dialogue: 0,0:00:47.86,0:00:52.17,jp,,0,0,0,,俺は  最近  クールなお姉ちゃんがきてると思う
Dialogue: 1,0:00:47.86,0:00:52.17,zh,,0,0,0,,我最近觉得高冷的姐姐最好
Dialogue: 0,0:00:52.17,0:00:54.17,jp,,0,0,0,,あの  ちょっと
Dialogue: 1,0:00:52.17,0:00:54.17,zh,,0,0,0,,那个 别…
Dialogue: 0,0:01:00.68,0:01:02.43,jp,,0,0,0,,綾は私が守る
Dialogue: 1,0:01:00.68,0:01:02.43,zh,,0,0,0,,小绫由我保护
Dialogue: 0,0:01:02.43,0:01:04.68,jp,,0,0,0,,かっこいい
Dialogue: 1,0:01:02.43,0:01:04.68,zh,,0,0,0,,好帅气
Dialogue: 0,0:01:06.18,0:01:09.46,jp,,0,0,0,,妹の前でさせないで下さいよ
Dialogue: 1,0:01:06.18,0:01:09.46,zh,,0,0,0,,别让我在妹妹面前演啊
Dialogue: 0,0:01:09.46,0:01:13.43,jp,,0,0,0,,ああ言うけど  お姉ちゃんは全力でやってくれんのよ
Dialogue: 1,0:01:09.46,0:01:13.43,zh,,0,0,0,,你姐姐嘴上抱怨 该演的时候还是全力演的
Dialogue: 0,0:01:13.43,0:01:15.60,jp,,0,0,0,,俺は心から尊敬してる
Dialogue: 1,0:01:13.43,0:01:15.60,zh,,0,0,0,,我打从心底尊敬她
Dialogue: 0,0:01:15.60,0:01:16.82,jp,,0,0,0,,ふーん
Dialogue: 1,0:01:15.60,0:01:16.82,zh,,0,0,0,,这样啊
Dialogue: 0,0:01:17.80,0:01:20.69,jp,,0,0,0,,じゃあ  ぐうたらお姉ちゃん知ってる？
Dialogue: 1,0:01:17.80,0:01:20.69,zh,,0,0,0,,那你见过懒虫姐姐吗
Dialogue: 0,0:01:21.95,0:01:23.30,jp,,0,0,0,,教えて  教えて
Dialogue: 1,0:01:21.95,0:01:23.30,zh,,0,0,0,,快跟我说
Dialogue: 0,0:01:26.78,0:01:29.72,jp,,0,0,0,,あのね  ソファーから動かなくなってね
Dialogue: 1,0:01:26.78,0:01:29.72,zh,,0,0,0,,是这样的 她会躺在沙发上一动不动
Dialogue: 0,0:01:29.72,0:01:31.88,jp,,0,0,0,,私がお世話してあげるの
Dialogue: 1,0:01:29.72,0:01:31.88,zh,,0,0,0,,我得照顾她
Dialogue: 0,0:01:32.73,0:01:34.11,jp,,0,0,0,,へー
Dialogue: 1,0:01:32.73,0:01:34.11,zh,,0,0,0,,哦？
Dialogue: 0,0:01:34.11,0:01:37.34,jp,,0,0,0,,つ  疲れた時だけですから  ほんと時々
Dialogue: 1,0:01:34.11,0:01:37.34,zh,,0,0,0,,只有太累的时候会 真的只是偶尔
Dialogue: 0,0:01:37.34,0:01:40.09,jp,,0,0,0,,ぐうたらちゃん見たいなあ
Dialogue: 1,0:01:37.34,0:01:40.09,zh,,0,0,0,,好想见见懒虫凛啊
Dialogue: 0,0:01:44.59,0:01:46.10,jp,,0,0,0,,もー
Dialogue: 1,0:01:44.59,0:01:46.10,zh,,0,0,0,,不行了
Dialogue: 0,0:01:47.53,0:01:51.10,jp,,0,0,0,,もー  動きたくなぁい
Dialogue: 1,0:01:47.53,0:01:51.10,zh,,0,0,0,,不行了 不想动了
Dialogue: 0,0:01:51.10,0:01:53.37,jp,,0,0,0,,家帰る時間だぞ
Dialogue: 1,0:01:51.10,0:01:53.37,zh,,0,0,0,,到回家的点了哦
Dialogue: 0,0:01:53.37,0:01:56.36,jp,,0,0,0,,綾香ちゃんだって  迎えに来てくれたのに
Dialogue: 1,0:01:53.37,0:01:56.36,zh,,0,0,0,,绫香都来接你了
Dialogue: 0,0:01:56.36,0:01:58.36,jp,,0,0,0,,やーあー
Dialogue: 1,0:01:56.36,0:01:58.36,zh,,0,0,0,,不想动了
Dialogue: 0,0:01:58.36,0:02:00.51,jp,,0,0,0,,お茶取って
Dialogue: 1,0:01:58.36,0:02:00.51,zh,,0,0,0,,帮我拿下茶
Dialogue: 0,0:02:00.51,0:02:02.11,jp,,0,0,0,,すぐそこにあるぞ
Dialogue: 1,0:02:00.51,0:02:02.11,zh,,0,0,0,,就在你边上哦
Dialogue: 0,0:02:02.11,0:02:05.45,jp,,0,0,0,,言うこと聞いてあげなきゃ  元に戻んないの
Dialogue: 1,0:02:02.11,0:02:05.45,zh,,0,0,0,,如果不满足她 她就会一直这样
Dialogue: 0,0:02:05.45,0:02:07.92,jp,,0,0,0,,よーし  任せとけ
Dialogue: 1,0:02:05.45,0:02:07.92,zh,,0,0,0,,好 交给我吧
Dialogue: 0,0:02:09.49,0:02:10.94,jp,,0,0,0,,はい  お茶だよ
Dialogue: 1,0:02:09.49,0:02:10.94,zh,,0,0,0,,茶来了
Dialogue: 0,0:02:12.23,0:02:14.06,jp,,0,0,0,,かわいいって言って
Dialogue: 1,0:02:12.23,0:02:14.06,zh,,0,0,0,,夸我可爱
Dialogue: 0,0:02:15.82,0:02:18.63,jp,,0,0,0,,私にも可愛いって言って
Dialogue: 1,0:02:15.82,0:02:18.63,zh,,0,0,0,,也夸夸我可爱啊
Dialogue: 0,0:02:20.88,0:02:23.00,jp,,0,0,0,,かわいいねぇ  お姉ちゃん
Dialogue: 1,0:02:20.88,0:02:23.00,zh,,0,0,0,,姐姐真可爱啊
Dialogue: 0,0:02:27.08,0:02:29.88,jp,,0,0,0,,いや  それもはやぐうたらじゃないし？
Dialogue: 1,0:02:27.08,0:02:29.88,zh,,0,0,0,,不对 这已经不叫懒虫了
Dialogue: 0,0:02:30.66,0:02:34.65,jp,,0,0,0,,あと  かわいいだけじゃないんだよなぁ  お姉ちゃんは
Dialogue: 1,0:02:30.66,0:02:34.65,zh,,0,0,0,,还有 姐姐可不只是可爱啊
Dialogue: 0,0:02:37.66,0:02:40.54,jp,,0,0,0,,なかなか元に戻らねーな
Dialogue: 1,0:02:37.66,0:02:40.54,zh,,0,0,0,,这都不肯恢复原样啊
Dialogue: 0,0:02:40.54,0:02:42.72,jp,,0,0,0,,相変わらず全力だな
Dialogue: 1,0:02:40.54,0:02:42.72,zh,,0,0,0,,真是一如既往地全力在演啊
